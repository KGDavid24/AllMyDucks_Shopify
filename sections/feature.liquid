<style>
  /* ── ALL MY BRAND FEATURE ───────────────────────────────
     Based on Slide 31: Generous white space, open layout,
     no text overlays, and strict typography hierarchy.
  ─────────────────────────────────────────────────────────── */

  .allmy-feature-{{ section.id }} {
    background-color: #F5F0E3; /* Warm Cream background */
    width: 100%;
    overflow: hidden;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .allmy-feature-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .allmy-feature__container {
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding: 0 24px;
  }

  @media screen and (min-width: 900px) {
    .allmy-feature__container {
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: 80px;
      padding: 0 56px;
    }
    
    /* Option to flip the layout left/right */
    .allmy-feature__container--reverse .allmy-feature__image-col {
      order: 2;
    }
    .allmy-feature__container--reverse .allmy-feature__text-col {
      order: 1;
    }
  }

  /* ── IMAGE COLUMN ───────────────────────────────────────── */
  .allmy-feature__image-col {
    position: relative;
    width: 100%;
    /* Creates a clean, structured frame for the image without clutter */
    aspect-ratio: 4 / 5; 
    overflow: hidden;
    border-radius: 2px;
  }

  .allmy-feature__image-col img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .allmy-feature__image-placeholder {
    width: 100%;
    height: 100%;
    background-color: #EDE8D9;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .allmy-feature__image-placeholder svg {
    width: 30%;
    opacity: 0.2;
  }

  /* ── TEXT COLUMN ────────────────────────────────────────── */
  .allmy-feature__text-col {
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 540px;
  }

  .allmy-feature__heading {
    /* Sofia speaks: used for emphasis and confident headers */
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    color: #2B2724; /* Deep Espresso */
    margin: 0 0 24px 0;
  }

  .allmy-feature__text {
    /* Outfit explains: used for clarity and longer text */
    font-family: var(--font-body-family);
    font-size: clamp(1.25rem, 3vw, 1.875rem); /* Much bigger, responsive scaling */
    line-height: 1.6;
    color: #2B2724; /* Deep Espresso */
    opacity: 0.8;
  }

  .allmy-feature__text p {
    margin: 0 0 16px 0;
  }
  
  .allmy-feature__text p:last-child {
    margin-bottom: 0;
  }
</style>

<section class="allmy-feature-{{ section.id }}">
  <div class="allmy-feature__container {% if section.settings.image_position == 'right' %}allmy-feature__container--reverse{% endif %}">
    
    {%- comment -%} ── IMAGE COLUMN ── {%- endcomment -%}
    <div class="allmy-feature__image-col">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 1200',
            sizes: '(max-width: 899px) 100vw, 50vw',
            alt: section.settings.image.alt | default: section.settings.heading
        }}
      {%- else -%}
        <div class="allmy-feature__image-placeholder">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── TEXT COLUMN ── {%- endcomment -%}
    <div class="allmy-feature__text-col">
      {%- if section.settings.heading != blank -%}
        <h2 class="allmy-feature__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="allmy-feature__text">
          {{ section.settings.text }}
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "ALL MY Brand Feature",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image",
      "info": "Avoid excessive text overlays on this image to maintain the brand's breathable aesthetic."
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Desktop Image Position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "INGREDIENTS",
      "info": "Uses Sofia Pro Soft. Keep it calm and confident."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body Text",
      "default": "<p>Premium doesn't have to mean pretentious. It can mean purposeful. Care doesn't have to cost the world. It can heal it.</p>",
      "info": "Uses Outfit. Explains the details clearly."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "ALL MY Brand Feature",
      "category": "Image"
    }
  ]
}
{% endschema %}