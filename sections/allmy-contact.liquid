<style>
  .allmy-contact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
  }

  /* LEFT PANEL */
  .allmy-contact__left {
    background-color: #2B2724;
    padding: 80px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .allmy-contact__eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #DACBA5;
    margin-bottom: 24px;
  }

  .allmy-contact__heading {
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.22;
    color: #F5F0E3;
    margin-bottom: 24px;
  }

  .allmy-contact__intro {
    font-size: 16px;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(245,240,227,0.7);
    margin-bottom: 48px;
  }

  .allmy-contact__direct-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(245,240,227,0.4);
    margin-bottom: 10px;
  }

  .allmy-contact__email {
    color: #F5F0E3;
    text-decoration: none;
    font-size: 18px;
    font-weight: 300;
    border-bottom: 1px solid rgba(245,240,227,0.25);
    padding-bottom: 4px;
    transition: border-color 0.2s ease;
    display: inline-block;
    margin-bottom: 40px;
  }

  .allmy-contact__email:hover {
    border-color: #dde6e3;
  }

  .allmy-contact__social-row {
    display: flex;
    gap: 20px;
  }

  .allmy-contact__social-link {
    color: rgba(245,240,227,0.5);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .allmy-contact__social-link:hover {
    color: #F5F0E3;
  }

  .allmy-contact__social-link svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* RIGHT PANEL (FORM) */
  .allmy-contact__right {
    background-color: #F5F0E3;
    padding: 80px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .allmy-contact__form-heading {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #2B2724;
    margin-bottom: 36px;
  }

  .allmy-contact__field {
    margin-bottom: 28px;
  }

  .allmy-contact__label {
    display: block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(43,39,36,0.55);
    margin-bottom: 10px;
  }

  .allmy-contact__input,
  .allmy-contact__textarea {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(43,39,36,0.25);
    color: #2B2724;
    font-size: 16px;
    font-weight: 300;
    padding: 8px 0 10px;
    outline: none;
    transition: border-color 0.2s ease;
    font-family: inherit;
    box-sizing: border-box;
  }

  .allmy-contact__input:focus,
  .allmy-contact__textarea:focus {
    border-color: #2B2724;
  }

  .allmy-contact__input::placeholder,
  .allmy-contact__textarea::placeholder {
    color: rgba(43,39,36,0.3);
  }

  .allmy-contact__textarea {
    resize: none;
    min-height: 100px;
  }

  .allmy-contact__submit {
    margin-top: 8px;
    background-color: #2B2724;
    color: #F5F0E3;
    border: none;
    padding: 16px 40px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.2s ease;
    font-family: inherit;
    align-self: flex-start;
  }

  .allmy-contact__submit:hover {
    background-color: #3d3532;
  }

  .allmy-contact__success {
    color: #2B2724;
    font-weight: 300;
    padding: 20px 0;
  }

  .allmy-contact__error {
    color: #c0392b;
    font-size: 14px;
    margin-bottom: 16px;
  }

  /* RESPONSIVE */
  @media screen and (max-width: 900px) {
    .allmy-contact { grid-template-columns: 1fr; }
    .allmy-contact__left,
    .allmy-contact__right { padding: 64px 28px; }
  }

  @media screen and (max-width: 480px) {
    .allmy-contact__left,
    .allmy-contact__right { padding: 48px 20px; }
    .allmy-contact__submit { width: 100%; text-align: center; }
  }
</style>

<section class="allmy-contact">

  <div class="allmy-contact__left">
    <p class="allmy-contact__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="allmy-contact__heading">{{ section.settings.heading }}</h1>
    <p class="allmy-contact__intro">{{ section.settings.intro }}</p>

    <p class="allmy-contact__direct-label">{{ section.settings.email_label }}</p>
    <a href="mailto:{{ section.settings.email }}" class="allmy-contact__email">{{ section.settings.email }}</a>

    <div class="allmy-contact__social-row">
      {%- if section.settings.instagram_url != blank -%}
        <a href="{{ section.settings.instagram_url }}" class="allmy-contact__social-link" aria-label="Instagram">
          <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          Instagram
        </a>
      {%- endif -%}
      {%- if section.settings.tiktok_url != blank -%}
        <a href="{{ section.settings.tiktok_url }}" class="allmy-contact__social-link" aria-label="TikTok">
          <svg viewBox="0 0 24 24"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
          TikTok
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="allmy-contact__right">
    <p class="allmy-contact__form-heading">{{ 'allmy.contact.form_heading' | t: default: 'Send us a message' }}</p>

    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <p class="allmy-contact__success">{{ 'allmy.contact.success' | t: default: 'Thanks -- we will be in touch soon.' }}</p>
      {% else %}
        <div class="allmy-contact__field">
          <label for="ContactFormName" class="allmy-contact__label">{{ 'allmy.contact.name_label' | t: default: 'Name' }}</label>
          <input
            type="text"
            id="ContactFormName"
            name="contact[name]"
            class="allmy-contact__input"
            placeholder="{{ 'allmy.contact.name_placeholder' | t: default: 'Your name' }}"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
          >
        </div>

        <div class="allmy-contact__field">
          <label for="ContactFormEmail" class="allmy-contact__label">{{ 'allmy.contact.email_label' | t: default: 'Email' }}</label>
          <input
            type="email"
            id="ContactFormEmail"
            name="contact[email]"
            class="allmy-contact__input"
            placeholder="{{ 'allmy.contact.email_placeholder' | t: default: 'your@email.com' }}"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            required
          >
        </div>

        <div class="allmy-contact__field">
          <label for="ContactFormMessage" class="allmy-contact__label">{{ 'allmy.contact.message_label' | t: default: 'Message' }}</label>
          <textarea
            id="ContactFormMessage"
            name="contact[body]"
            class="allmy-contact__textarea"
            placeholder="{{ 'allmy.contact.message_placeholder' | t: default: 'How can we help?' }}"
            rows="5"
          >{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>

        {% if form.errors %}
          <p class="allmy-contact__error">{{ form.errors | default_errors }}</p>
        {% endif %}

        <button type="submit" class="allmy-contact__submit">{{ 'allmy.contact.submit' | t: default: 'Send message' }}</button>
      {% endif %}
    {% endform %}
  </div>

</section>

{% schema %}
{
  "name": "Contact",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Contact"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We read every message."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro text",
      "default": "Questions about a product, your order, or just curious how concentrates work — we are happy to help. No bots, no ticket queues."
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email us directly"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "hello@allmyducks.com"
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    }
  ],
  "presets": [
    {
      "name": "Contact"
    }
  ]
}
{% endschema %}
