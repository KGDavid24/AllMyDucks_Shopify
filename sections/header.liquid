<style>
  .custom-brand-header {
    position: relative; /* Added to map the absolute centering */
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30px 50px; 
    background-color: #F5F0E3; /* Warm Cream */
    color: #2B2724; /* Deep Espresso */
  }
  
  .custom-header-left, .custom-header-right {
    display: flex;
    align-items: center;
    gap: 40px;
  }
  
  .custom-brand-name {
    /* Font-family removed: controlled by Google Fonts App via .custom-brand-name */
    font-weight: bold;
    font-size: 24px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: #2B2724;
  }
  
  .custom-menu-nav {
    display: flex;
    gap: 30px;
    align-items: center;
  }
  
  .custom-menu-link {
    /* Font-family removed: controlled by Google Fonts App via .custom-menu-link */
    text-decoration: none;
    color: #2B2724; 
    font-size: 16px;
    font-weight: 500;
  }
  
  .custom-center-logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .custom-center-logo a {
    display: block;
    position: relative;
  }

  .custom-center-logo img {
    height: 70px;
    display: block;
  }

  .custom-center-logo__hover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .custom-center-logo a:hover .custom-center-logo__hover {
    opacity: 1;
  }

  /* ── SEARCH BAR STYLES ── */
  .custom-search-container {
    display: flex;
    align-items: center;
  }

  .custom-search-form {
    width: 0;
    opacity: 0;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
  }

  .custom-search-form.is-open {
    width: 180px;
    opacity: 1;
    margin-right: 15px; /* Space between input and button */
  }

  .custom-search-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid #2B2724;
    color: #2B2724;
    font-size: 16px;
    padding: 4px 0;
    outline: none;
  }

  .custom-search-input::placeholder {
    color: rgba(43, 39, 36, 0.5);
  }

  /* Reset button styles to match regular links */
  button.custom-search-toggle {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: inherit;
  }

  @media screen and (max-width: 989px) {
    .custom-brand-header {
      display: none;
    }
  }
</style>

<header class="custom-brand-header">
  <div class="custom-header-left">
    <a href="/" class="custom-brand-name">ALL MY DUCKS</a>
    <nav class="custom-menu-nav">
      {% for link in linklists['left-menu'].links %}
        <a href="{{ link.url }}" class="custom-menu-link">{{ link.title }}</a>
      {% endfor %}
    </nav>
  </div>

  <div class="custom-center-logo">
    <a href="/">
      <img src="{{ 'brand-logo-ducks.svg' | file_url }}" alt="All My Ducks" width="120" height="70">
      <img src="{{ 'brand-logo-ducks-mid-amber.png' | file_url }}" alt="" width="120" height="70" class="custom-center-logo__hover" aria-hidden="true">
    </a>
  </div>

  <div class="custom-header-right">
    <nav class="custom-menu-nav">
     
      <div class="custom-search-container">
        <form action="{{ routes.search_url }}" method="get" class="custom-search-form" id="custom-search-form">
          <input type="text" name="q" placeholder="Search..." class="custom-search-input" id="custom-search-input">
          <input type="hidden" name="type" value="product">
        </form>
        <button type="button" class="custom-menu-link custom-search-toggle" id="custom-search-toggle">Search</button>
      </div>

      {% for link in linklists['right-menu'].links %}
        {% assign link_title_down = link.title | downcase %}
        {% if link_title_down == 'search' %}
          {% continue %}
        {% endif %}
        <a href="{{ link.url }}" class="custom-menu-link">{{ link.title }}</a>
      {% endfor %}
      
      <a href="{{ routes.cart_url }}" class="custom-menu-link" id="custom-cart-link">
        Bag ({{ cart.item_count }})
      </a>
    </nav>
  </div>
</header>

<div id="cart-icon-bubble" aria-hidden="true" style="display:none"></div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchToggle = document.getElementById('custom-search-toggle');
    const searchForm = document.getElementById('custom-search-form');
    const searchInput = document.getElementById('custom-search-input');

    searchToggle.addEventListener('click', (e) => {
      e.preventDefault();

      if (searchForm.classList.contains('is-open') && searchInput.value.trim() !== '') {
        searchForm.submit();
      } else {
        searchForm.classList.toggle('is-open');
        if (searchForm.classList.contains('is-open')) {
          searchInput.focus();
        }
      }
    });

    document.addEventListener('click', (e) => {
      if (!searchForm.contains(e.target) && e.target !== searchToggle) {
        searchForm.classList.remove('is-open');
      }
    });

    // Keep Bag (n) in sync after any AJAX cart change.
    // cart.js publishes cartUpdate with parsedState after every mutation.
    // We subscribe here; the hidden #cart-icon-bubble div above stops
    // cart.js from throwing before it reaches publish().
    const cartLink = document.getElementById('custom-cart-link');
    if (cartLink && typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
      subscribe(PUB_SUB_EVENTS.cartUpdate, (event) => {
        if (event && event.cartData && typeof event.cartData.item_count === 'number') {
          cartLink.textContent = 'Bag (' + event.cartData.item_count + ')';
        } else {
          fetch('/cart.js')
            .then((r) => r.json())
            .then((cart) => { cartLink.textContent = 'Bag (' + cart.item_count + ')'; });
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Custom Brand Header",
  "presets": [
    {
      "name": "Custom Brand Header"
    }
  ]
}
{% endschema %}