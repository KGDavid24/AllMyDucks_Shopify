<style>
  .custom-htu-section {
    width: 100%;
    background-image: url('{{ section.settings.bg_image | img_url: 'master' }}');
    background-color: #F5F0E3;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 30px 50px;
    display: flex;
    justify-content: flex-start;
    overflow: hidden; /* Prevents horizontal scroll if table moves too far right */
  }

  .custom-htu-container {
    /* Uses the expanded slider value (0-75%) to position the table */
    margin-left: {{ section.settings.table_offset }}%; 
    width: 50%;
    max-width: 550px;
    display: flex;
    flex-direction: column;
    color: #2B2724; 
  }

  /* --- ICONS (TOP RIGHT OF CONTAINER) --- */
  .custom-htu-icons {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 20px;
    margin-bottom: 30px; 
    flex-wrap: wrap;
  }

  .custom-htu-icon {
    height: 100px; /* Maintains the enlarged size */
    width: auto;
    object-fit: contain;
  }

  /* --- TABLE ROWS --- */
  .custom-htu-table {
    display: flex;
    flex-direction: column;
  }

  .custom-htu-row {
    padding: 20px 0;
    border-bottom: 2px solid #2B2724;
  }

  .custom-htu-row.layout-split {
    display: flex;
    gap: 40px;
  }

  .custom-htu-row.layout-split .custom-htu-heading {
    flex: 0 0 200px;
  }

  .custom-htu-row.layout-stacked .custom-htu-heading {
    margin-bottom: 15px;
  }

  /* --- TYPOGRAPHY --- */
  .custom-htu-heading {
    text-transform: uppercase;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.2;
  }

  .custom-htu-content {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.6;
  }

  @media screen and (max-width: 900px) {
    .custom-htu-section {
      padding: 40px 20px;
    }
    .custom-htu-container {
      width: 100%;
      margin-left: 0 !important;
      background: rgba(245, 240, 227, 0.9);
      padding: 30px;
    }
    .custom-htu-row.layout-split {
      flex-direction: column;
      gap: 15px;
    }
  }
</style>

<section class="custom-htu-section">
  <div class="custom-htu-container">
    
    <div class="custom-htu-icons">
      {% for block in section.blocks %}
        {% if block.type == 'icon' %}
          <img src="{{ block.settings.icon_image | img_url: '200x' }}" class="custom-htu-icon" alt="Icon" {{ block.shopify_attributes }}>
        {% endif %}
      {% endfor %}
    </div>

    <div class="custom-htu-table">
      {% if product.metafields.custom.how_to_use.value != blank %}
        <div class="custom-htu-row layout-stacked">
          <div class="custom-htu-heading">HOW TO USE</div>
          <div class="custom-htu-content">
            {{ product.metafields.custom.how_to_use.value }}
          </div>
        </div>
      {% endif %}

      {% if product.metafields.custom.active_ingredients.value != blank %}
        <div class="custom-htu-row layout-split">
          <div class="custom-htu-heading">ACTIVE INGREDIENTS</div>
          <div class="custom-htu-content">
            {{ product.metafields.custom.active_ingredients.value }}
          </div>
        </div>
      {% endif %}

      {% if product.metafields.custom.aroma.value != blank %}
        <div class="custom-htu-row layout-split" style="border: none;">
          <div class="custom-htu-heading">AROMA</div>
          <div class="custom-htu-content">
            {{ product.metafields.custom.aroma.value }}
          </div>
        </div>
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "How To Use Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Texture"
    },
    {
      "type": "range",
      "id": "table_offset",
      "min": 0,
      "max": 75,
      "step": 1,
      "unit": "%",
      "label": "Table Horizontal Position",
      "default": 50,
      "info": "Slide to move the table from left (0) to right (75)."
    }
  ],
  "blocks": [
    {
      "type": "icon",
      "name": "Top Right Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How To Use Banner"
    }
  ]
}
{% endschema %}