<style>
  .allmy-announcement {
    background-color: #2B2724;
    color: #F5F0E3;
    text-align: center;
    padding: 10px 24px;
    font-family: 'Outfit', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .allmy-announcement__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    flex-wrap: wrap;
  }

  .allmy-announcement__item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #F5F0E3;
  }

  .allmy-announcement__sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #DACBA5;
    flex-shrink: 0;
  }

  @media screen and (max-width: 600px) {
    .allmy-announcement {
      font-size: 11px;
      padding: 9px 16px;
    }
    .allmy-announcement__sep {
      display: none;
    }
    .allmy-announcement__inner {
      gap: 6px;
      flex-direction: column;
    }
  }
</style>

<div class="allmy-announcement" role="complementary" aria-label="Store announcement">
  <div class="allmy-announcement__inner">
    <span class="allmy-announcement__item">No water shipped</span>
    <span class="allmy-announcement__sep" aria-hidden="true"></span>
    <span class="allmy-announcement__item">0% filler</span>
    <span class="allmy-announcement__sep" aria-hidden="true"></span>
    <span class="allmy-announcement__item">Free EU shipping over &euro;35</span>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
