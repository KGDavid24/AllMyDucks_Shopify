<style>
  .custom-brand-footer {
    background-color: #F5F0E3; /* Warm Cream */
    color: #2B2724; /* Deep Espresso */
    padding: 80px 50px 30px; 
  }
  
  .custom-footer-top {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 50px;
    margin-bottom: 60px;
  }
  
  .custom-footer-col {
    flex: 1;
    min-width: 250px;
  }
  
  .custom-footer-heading {
    /* Controlled by Google Fonts App via .custom-footer-heading */
    font-weight: bold;
    font-size: 18px;
    margin-bottom: 25px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #2B2724;
  }
  
  .custom-footer-brand-img {
    height: 45px; 
    display: block;
    margin-bottom: 20px;
  }

  .custom-footer-social-img {
    height: 85px; 
    display: block;
    margin-bottom: 20px;
  }
  
  .custom-footer-text {
    /* Controlled by Google Fonts App via .custom-footer-text */
    font-size: 16px;
    line-height: 1.6;
    color: #2B2724;
    max-width: 320px;
  }
  
  .custom-footer-link {
    /* Controlled by Google Fonts App via .custom-footer-link */
    display: block;
    text-decoration: none;
    color: #2B2724;
    font-size: 16px;
    margin-bottom: 15px;
    transition: opacity 0.2s ease;
  }
  
  .custom-footer-link:hover {
    opacity: 0.7;
  }

  /* NEW MINIMALIST ICON STYLES */
  .custom-social-icons {
    display: flex;
    gap: 24px;
    margin-bottom: 25px;
  }

  .custom-social-link {
    color: #2B2724; /* FIX: Overrides the default browser blue for links */
    display: inline-flex;
  }

  .custom-social-link svg {
    width: 22px;
    height: 22px;
    fill: none; 
    stroke: currentColor; /* Now correctly inherits Deep Espresso from .custom-social-link */
    stroke-width: 1.5; 
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: opacity 0.2s ease;
  }

  .custom-social-link:hover svg {
    opacity: 0.6;
  }

  .custom-footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(43, 39, 36, 0.1); 
    padding-top: 30px;
    flex-wrap: wrap;
    gap: 20px;
  }
  
  .custom-footer-bottom-text {
    /* Controlled by Google Fonts App via .custom-footer-text */
    font-size: 14px;
    color: #2B2724;
    text-decoration: none;
  }

  @media screen and (max-width: 768px) {
    .custom-brand-footer {
      padding: 50px 20px 20px;
    }
    .custom-footer-top {
      flex-direction: column;
      gap: 40px;
    }
    .custom-footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<footer class="custom-brand-footer">
  <div class="custom-footer-top">
    
    <div class="custom-footer-col">
      <img src="{{ 'icon2.png' | file_url }}" alt="All My Ducks" class="custom-footer-brand-img">
      <p class="custom-footer-text">
        Premium doesn't have to mean pretentious. It can mean purposeful. Care doesn't have to cost the world. It can heal it.
      </p>
    </div>

    <div class="custom-footer-col">
      <div class="custom-footer-heading">Shop</div>
      <a href="/collections/all" class="custom-footer-link">All Products</a>
      <a href="/pages/about" class="custom-footer-link">Our Story</a>
      <a href="/pages/why-eco" class="custom-footer-link">Why Eco</a>
      <a href="/pages/faqs" class="custom-footer-link">FAQs</a>
    </div>

    <div class="custom-footer-col">
      <img src="{{ 'icon3.png' | file_url }}" alt="Follow The Ducks!" class="custom-footer-social-img">
      
      <div class="custom-social-icons">
        <a href="#" class="custom-social-link" aria-label="Facebook">
          <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <a href="#" class="custom-social-link" aria-label="Instagram">
          <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="#" class="custom-social-link" aria-label="TikTok">
          <svg viewBox="0 0 24 24"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
        </a>
      </div>
      
      <a href="/pages/contact" class="custom-footer-link">Contact Us</a>
    </div>
    
  </div>

  <div class="custom-footer-bottom">
    <span class="custom-footer-bottom-text">&copy; {{ 'now' | date: "%Y" }} ALL MY DUCKS. All rights reserved.</span>
    <div>
      <a href="/policies/privacy-policy" class="custom-footer-bottom-text" style="margin-right: 20px;">Privacy Policy</a>
      <a href="/policies/terms-of-service" class="custom-footer-bottom-text">Terms of Service</a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Brand Footer",
  "presets": [
    {
      "name": "Custom Brand Footer"
    }
  ]
}
{% endschema %}