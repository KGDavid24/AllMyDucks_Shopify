<style>
  .allmy-ti-{{ section.id }} {
    background: {{ section.settings.bg_color }};
  }

  .allmy-ti-{{ section.id }}__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: {{ section.settings.min_height }}px;
  }

  .allmy-ti-{{ section.id }}__media {
    overflow: hidden;
    position: relative;
    {%- if section.settings.image_side == 'right' %}order: 1;{%- endif %}
  }

  .allmy-ti-{{ section.id }}__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_focus }};
    display: block;
  }

  .allmy-ti-{{ section.id }}__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: {{ section.settings.pad_v }}px {{ section.settings.pad_h }}px;
    {%- if section.settings.image_side == 'right' %}order: 0;{%- endif %}
  }

  .allmy-ti-{{ section.id }}__heading {
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: clamp(26px, 3.5vw, 46px);
    line-height: 1.15;
    color: {{ section.settings.text_color }};
    margin: 0 0 22px;
  }

  .allmy-ti-{{ section.id }}__body {
    font-family: var(--font-body-family);
    font-size: 16px;
    font-weight: 300;
    line-height: 1.75;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
    margin: 0 0 32px;
  }

  .allmy-ti-{{ section.id }}__body p { margin: 0 0 12px; }
  .allmy-ti-{{ section.id }}__body p:last-child { margin-bottom: 0; }

  .allmy-ti-{{ section.id }}__stat {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 32px;
    padding: 20px 24px;
    background: {{ section.settings.stat_bg }};
    border-left: 3px solid {{ section.settings.accent_color }};
  }

  .allmy-ti-{{ section.id }}__stat-value {
    font-family: var(--font-heading-family);
    font-size: 2.8rem;
    font-weight: 700;
    color: {{ section.settings.accent_color }};
    line-height: 1;
    flex-shrink: 0;
  }

  .allmy-ti-{{ section.id }}__stat-label {
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.45;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
  }

  .allmy-ti-{{ section.id }}__image--mobile { display: none; }

  @media screen and (max-width: 900px) {
    .allmy-ti-{{ section.id }}__grid {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .allmy-ti-{{ section.id }}__media {
      order: {%- if section.settings.image_mobile == 'below' %} 1{%- else %} 0{%- endif %};
      height: {{ section.settings.img_mobile_height }}px;
      min-height: 200px;
    }
    .allmy-ti-{{ section.id }}__text {
      order: {%- if section.settings.image_mobile == 'below' %} 0{%- else %} 1{%- endif %};
      padding: {{ section.settings.pad_v_mobile }}px 24px;
    }
    {%- if section.settings.mobile_image != blank -%}
      .allmy-ti-{{ section.id }}__image--desktop { display: none; }
      .allmy-ti-{{ section.id }}__image--mobile { display: block; }
    {%- endif -%}
  }
</style>

<section class="allmy-ti-{{ section.id }}">
  <div class="allmy-ti-{{ section.id }}__grid">

    <div class="allmy-ti-{{ section.id }}__media">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1400 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
          class="allmy-ti-{{ section.id }}__image allmy-ti-{{ section.id }}__image--desktop"
          loading="lazy"
          width="1400"
          height="1000"
        >
      {%- else -%}
        <div style="width:100%;height:100%;min-height:400px;background:#EDE8D9;display:flex;align-items:center;justify-content:center;opacity:.4;">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
      {%- if section.settings.mobile_image != blank -%}
        <img
          src="{{ section.settings.mobile_image | image_url: width: 800 }}"
          alt="{{ section.settings.mobile_image.alt | default: section.settings.heading | escape }}"
          class="allmy-ti-{{ section.id }}__image allmy-ti-{{ section.id }}__image--mobile"
          loading="lazy"
          width="800"
          height="800"
        >
      {%- endif -%}
    </div>

    <div class="allmy-ti-{{ section.id }}__text">
      {% render 'allmy-eyebrow', text: section.settings.eyebrow, color: section.settings.eyebrow_color %}

      {%- if section.settings.heading != blank -%}
        <h2 class="allmy-ti-{{ section.id }}__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.stat_value != blank -%}
        <div class="allmy-ti-{{ section.id }}__stat">
          <span class="allmy-ti-{{ section.id }}__stat-value">{{ section.settings.stat_value }}</span>
          <span class="allmy-ti-{{ section.id }}__stat-label">{{ section.settings.stat_label }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="allmy-ti-{{ section.id }}__body">{{ section.settings.body }}</div>
      {%- endif -%}

      {% render 'allmy-btn-link', label: section.settings.btn_label, url: section.settings.btn_url, style: section.settings.btn_style %}
    </div>

  </div>
</section>

