<style>
  .allmy-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: calc(100vh - 56px);
    overflow: hidden;
  }

  /* ── LEFT PANEL ── */
  .allmy-hero__left {
    position: relative;
    overflow: hidden;
  }

  .allmy-hero__left-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-color: #1a1a1a;
  }

  .allmy-hero__left-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(100%);
  }

  .allmy-hero__left-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.28);
  }

  .allmy-hero__left-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 56px;
  }

  .allmy-hero__heading {
    font-family: 'Comfortaa', sans-serif;
    font-size: clamp(2.8rem, 5vw, 5.5rem);
    font-weight: 700;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-align: center;
    line-height: 1.05;
    margin: 0;
  }

  .allmy-hero__tagline {
    position: absolute;
    bottom: 44px;
    left: 48px;
    right: 48px;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.7;
    text-align: center;
  }

  /* ── RIGHT PANEL ── */
  .allmy-hero__right {
    position: relative;
    overflow: hidden;
  }

  .allmy-hero__right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── RESPONSIVE ── */
  @media screen and (max-width: 768px) {
    .allmy-hero {
      grid-template-columns: 1fr;
      grid-template-rows: 60vh 40vh;
      height: auto;
    }

    .allmy-hero__left-content {
      padding: 36px;
    }

    .allmy-hero__tagline {
      bottom: 28px;
      left: 28px;
      right: 28px;
    }
  }
</style>

<div class="allmy-hero">

  <div class="allmy-hero__left">
    <div class="allmy-hero__left-bg">
      {%- if section.settings.image_left -%}
        <img
          src="{{ section.settings.image_left | image_url: width: 1400 }}"
          alt="{{ section.settings.heading | escape }}"
          loading="eager"
        >
      {%- else -%}
        <img
          src="{{ 'hero1.png' | file_url }}"
          alt="{{ section.settings.heading | escape }}"
          loading="eager"
        >
      {%- endif -%}
    </div>
    <div class="allmy-hero__left-overlay"></div>
    <div class="allmy-hero__left-content">
      <h2 class="allmy-hero__heading">{{ section.settings.heading | default: 'INGREDIENTS' }}</h2>
    </div>
    {%- if section.settings.tagline != blank -%}
      <p class="allmy-hero__tagline">{{ section.settings.tagline | strip_html }}</p>
    {%- endif -%}
  </div>

  <div class="allmy-hero__right">
    {%- if section.settings.image_right -%}
      <img
        src="{{ section.settings.image_right | image_url: width: 1400 }}"
        alt="ALL MY DUCKS product"
        loading="eager"
      >
    {%- else -%}
      <img
        src="{{ 'hero2.png' | file_url }}"
        alt="ALL MY DUCKS product"
        loading="eager"
      >
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "Custom Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Left image"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Right image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Left heading",
      "default": "INGREDIENTS"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline (bottom of left panel)",
      "default": "Premium doesn't have to mean pretentious. It can mean purposeful. Care doesn't have to cost the world. It can heal it."
    }
  ],
  "presets": [
    {
      "name": "Custom Hero Banner"
    }
  ]
}
{% endschema %}
