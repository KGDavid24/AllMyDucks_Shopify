<style>
  .allmy-faq {
    background-color: #F5F0E3;
    padding: 100px 50px;
  }

  .allmy-faq__inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .allmy-faq__eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #C9B2A3;
    margin-bottom: 16px;
  }

  .allmy-faq__heading {
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: 38px;
    line-height: 1.22;
    color: #2B2724;
    margin-bottom: 56px;
  }

  .allmy-faq__category {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #2B2724;
    padding: 20px 0 12px;
    border-top: 2px solid #2B2724;
    margin-top: 48px;
  }

  .allmy-faq__category:first-of-type { margin-top: 0; }

  .allmy-faq__item {
    border-bottom: 1px solid rgba(43,39,36,0.12);
  }

  .allmy-faq__question {
    width: 100%;
    background: transparent;
    border: none;
    padding: 22px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    text-align: left;
    gap: 20px;
  }

  .allmy-faq__question-text {
    font-size: 16px;
    font-weight: 500;
    color: #2B2724;
    line-height: 1.45;
  }

  .allmy-faq__chevron {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .allmy-faq__item.is-open .allmy-faq__chevron { transform: rotate(180deg); }

  .allmy-faq__answer {
    display: none;
    padding: 0 0 24px;
    font-size: 15px;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(43,39,36,0.8);
  }

  .allmy-faq__item.is-open .allmy-faq__answer { display: block; }
  .allmy-faq__answer p + p { margin-top: 14px; }

  .allmy-faq__footer {
    margin-top: 64px;
    background-color: #2B2724;
    color: #F5F0E3;
    padding: 48px;
    text-align: center;
  }

  .allmy-faq__footer-heading {
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: 24px;
    color: #F5F0E3;
    margin-bottom: 12px;
  }

  .allmy-faq__footer-sub {
    font-size: 15px;
    font-weight: 300;
    color: rgba(245,240,227,0.7);
    margin-bottom: 28px;
  }

  .allmy-faq__footer-link {
    display: inline-block;
    color: #F5F0E3;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-bottom: 1px solid rgba(245,240,227,0.4);
    padding-bottom: 3px;
    transition: border-color 0.2s ease;
  }

  .allmy-faq__footer-link:hover { border-color: #F5F0E3; }

  @media screen and (max-width: 768px) {
    .allmy-faq { padding: 64px 24px; }
    .allmy-faq__heading { font-size: 28px; }
    .allmy-faq__footer { padding: 40px 24px; }
  }

  @media screen and (max-width: 480px) {
    .allmy-faq { padding: 48px 16px; }
    .allmy-faq__heading { font-size: 24px; }
  }
</style>

<section class="allmy-faq">
  <div class="allmy-faq__inner">

    <p class="allmy-faq__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="allmy-faq__heading">{{ section.settings.heading }}</h1>

    {%- for block in section.blocks -%}
      {%- if block.type == 'category' -%}
        <p class="allmy-faq__category" {{ block.shopify_attributes }}>{{ block.settings.label }}</p>

      {%- elsif block.type == 'item' -%}
        <div class="allmy-faq__item" {{ block.shopify_attributes }}>
          <button class="allmy-faq__question" aria-expanded="false">
            <span class="allmy-faq__question-text">{{ block.settings.question }}</span>
            <svg class="allmy-faq__chevron" viewBox="0 0 24 24" fill="none" stroke="#2B2724" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="allmy-faq__answer">
            {{ block.settings.answer }}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

    <div class="allmy-faq__footer">
      <h2 class="allmy-faq__footer-heading">{{ section.settings.footer_heading }}</h2>
      <p class="allmy-faq__footer-sub">{{ section.settings.footer_sub }}</p>
      <a href="{{ section.settings.footer_link }}" class="allmy-faq__footer-link">{{ section.settings.footer_link_label }}</a>
    </div>

  </div>
</section>

<script>
  document.querySelectorAll('.allmy-faq__question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.allmy-faq__item');
      const isOpen = item.classList.contains('is-open');
      document.querySelectorAll('.allmy-faq__item.is-open').forEach(el => {
        el.classList.remove('is-open');
        el.querySelector('.allmy-faq__question').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everything you need to know."
    },
    {
      "type": "header",
      "content": "Footer CTA"
    },
    {
      "type": "text",
      "id": "footer_heading",
      "label": "Footer heading",
      "default": "Still have questions?"
    },
    {
      "type": "text",
      "id": "footer_sub",
      "label": "Footer subtext",
      "default": "We are a small team and we read every message."
    },
    {
      "type": "url",
      "id": "footer_link",
      "label": "Footer button link"
    },
    {
      "type": "text",
      "id": "footer_link_label",
      "label": "Footer button label",
      "default": "Get in touch"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category label",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Category name",
          "default": "General"
        }
      ]
    },
    {
      "type": "item",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Your question here?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Your answer here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "category", "settings": { "label": "Understanding Concentrates" } },
        { "type": "item", "settings": { "question": "What is a concentrate and how does it work?", "answer": "<p>A concentrate is a highly potent formula designed to be diluted with water before use. Instead of paying for a bottle that's 90% water, you buy the 10% that actually does the work — then add your own water at home.</p><p>The result is the same (or better) cleaning power, with dramatically less packaging, weight, and carbon cost from shipping.</p>" } },
        { "type": "item", "settings": { "question": "Do I need to buy a separate bottle to use the concentrate?", "answer": "<p>Yes — concentrates are meant to be diluted into a reusable dispenser or spray bottle, which you'll keep and refill. Any clean dispenser will work.</p>" } },
        { "type": "item", "settings": { "question": "Is concentrate safe for sensitive skin?", "answer": "<p>Our formulas are free from harsh sulfates, synthetic fragrances, and aggressive preservatives. Once diluted to the recommended ratio, they are safe for regular use on skin.</p>" } },
        { "type": "category", "settings": { "label": "Orders & Shipping" } },
        { "type": "item", "settings": { "question": "Where do you ship to?", "answer": "<p>We currently ship across the EU. Free shipping is available on all orders over €35. Delivery typically takes 3–5 business days.</p>" } },
        { "type": "item", "settings": { "question": "What is your return policy?", "answer": "<p>If you are not satisfied, contact us within 14 days of delivery and we will make it right — exchange, refund, or credit, your choice.</p>" } }
      ]
    }
  ]
}
{% endschema %}
