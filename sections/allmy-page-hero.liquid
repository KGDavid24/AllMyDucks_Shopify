<style>
  .allmy-ph-{{ section.id }} {
    position: relative;
    display: flex;
    align-items: {{ section.settings.vertical_align }};
    min-height: {{ section.settings.min_height }}px;
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 80px {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  .allmy-ph-{{ section.id }}__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_focus }};
  }

  .allmy-ph-{{ section.id }}__overlay {
    position: absolute;
    inset: 0;
    background: {{ section.settings.bg_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .allmy-ph-{{ section.id }}__content {
    position: relative;
    z-index: 1;
    max-width: {{ section.settings.content_width }}px;
    {%- if section.settings.text_align == 'center' %}
      margin: 0 auto;
      text-align: center;
    {%- elsif section.settings.text_align == 'right' %}
      margin-left: auto;
      text-align: right;
    {%- endif %}
  }

  .allmy-ph-{{ section.id }}__heading {
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: clamp(36px, 5.5vw, 76px);
    line-height: 1.1;
    color: {{ section.settings.text_color }};
    margin: 0 0 24px;
  }

  .allmy-ph-{{ section.id }}__subtext {
    font-family: var(--font-body-family);
    font-size: clamp(16px, 2vw, 20px);
    font-weight: 300;
    line-height: 1.7;
    color: {{ section.settings.text_color }};
    opacity: 0.78;
    max-width: 600px;
    margin: 0 0 40px;
    {%- if section.settings.text_align == 'center' %}margin-left: auto; margin-right: auto;{%- endif %}
  }

  @media screen and (max-width: 768px) {
    .allmy-ph-{{ section.id }} {
      padding: {{ section.settings.padding_top | times: 0.55 | round }}px 24px {{ section.settings.padding_bottom | times: 0.55 | round }}px;
      min-height: {{ section.settings.min_height | times: 0.65 | round }}px;
    }
  }
</style>

<section class="allmy-ph-{{ section.id }}">
  {%- if section.settings.bg_image != blank -%}
    <img
      src="{{ section.settings.bg_image | image_url: width: 2400 }}"
      alt=""
      class="allmy-ph-{{ section.id }}__bg"
      loading="eager"
      fetchpriority="high"
      width="2400"
      height="1200"
    >
    <div class="allmy-ph-{{ section.id }}__overlay"></div>
  {%- endif -%}

  <div class="allmy-ph-{{ section.id }}__content">
    {% render 'allmy-eyebrow', text: section.settings.eyebrow, color: section.settings.eyebrow_color %}

    {%- if section.settings.heading != blank -%}
      <h1 class="allmy-ph-{{ section.id }}__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="allmy-ph-{{ section.id }}__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {% render 'allmy-btn-link', label: section.settings.btn_label, url: section.settings.btn_url, style: section.settings.btn_style %}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.allmy-page-hero.name",
  "settings": [
    { "type": "header", "content": "t:sections.allmy-page-hero.settings.header__content.content" },
    { "type": "text", "id": "eyebrow", "label": "t:sections.allmy-page-hero.settings.eyebrow.label" },
    { "type": "text", "id": "heading", "label": "t:sections.allmy-page-hero.settings.heading.label", "default": "A different kind of clean." },
    { "type": "textarea", "id": "subtext", "label": "t:sections.allmy-page-hero.settings.subtext.label" },
    { "type": "header", "content": "t:sections.allmy-page-hero.settings.header__button.content" },
    { "type": "text", "id": "btn_label", "label": "t:sections.allmy-page-hero.settings.btn_label.label" },
    { "type": "url", "id": "btn_url", "label": "t:sections.allmy-page-hero.settings.btn_url.label" },
    {
      "type": "select", "id": "btn_style", "label": "t:sections.allmy-page-hero.settings.btn_style.label",
      "options": [
        { "value": "dark", "label": "t:sections.allmy-page-hero.settings.btn_style.options__1.label" },
        { "value": "light", "label": "t:sections.allmy-page-hero.settings.btn_style.options__2.label" },
        { "value": "amber", "label": "t:sections.allmy-page-hero.settings.btn_style.options__3.label" },
        { "value": "outline-dark", "label": "t:sections.allmy-page-hero.settings.btn_style.options__4.label" },
        { "value": "outline-light", "label": "t:sections.allmy-page-hero.settings.btn_style.options__5.label" }
      ],
      "default": "light"
    },
    { "type": "header", "content": "t:sections.allmy-page-hero.settings.header__layout.content" },
    {
      "type": "select", "id": "text_align", "label": "t:sections.allmy-page-hero.settings.text_align.label",
      "options": [
        { "value": "left", "label": "t:sections.allmy-page-hero.settings.text_align.options__1.label" },
        { "value": "center", "label": "t:sections.allmy-page-hero.settings.text_align.options__2.label" },
        { "value": "right", "label": "t:sections.allmy-page-hero.settings.text_align.options__3.label" }
      ],
      "default": "center"
    },
    {
      "type": "select", "id": "vertical_align", "label": "t:sections.allmy-page-hero.settings.vertical_align.label",
      "options": [
        { "value": "flex-start", "label": "t:sections.allmy-page-hero.settings.vertical_align.options__1.label" },
        { "value": "center", "label": "t:sections.allmy-page-hero.settings.vertical_align.options__2.label" },
        { "value": "flex-end", "label": "t:sections.allmy-page-hero.settings.vertical_align.options__3.label" }
      ],
      "default": "center"
    },
    { "type": "range", "id": "min_height", "label": "t:sections.allmy-page-hero.settings.min_height.label", "min": 200, "max": 900, "step": 20, "default": 500 },
    { "type": "range", "id": "content_width", "label": "t:sections.allmy-page-hero.settings.content_width.label", "min": 400, "max": 1200, "step": 40, "default": 840 },
    { "type": "range", "id": "padding_top", "label": "t:sections.allmy-page-hero.settings.padding_top.label", "min": 40, "max": 200, "step": 8, "default": 112 },
    { "type": "range", "id": "padding_bottom", "label": "t:sections.allmy-page-hero.settings.padding_bottom.label", "min": 40, "max": 200, "step": 8, "default": 112 },
    { "type": "header", "content": "t:sections.allmy-page-hero.settings.header__background.content" },
    { "type": "image_picker", "id": "bg_image", "label": "t:sections.allmy-page-hero.settings.bg_image.label" },
    {
      "type": "select", "id": "image_focus", "label": "t:sections.allmy-page-hero.settings.image_focus.label",
      "options": [
        { "value": "center center", "label": "t:sections.allmy-page-hero.settings.image_focus.options__1.label" },
        { "value": "top center", "label": "t:sections.allmy-page-hero.settings.image_focus.options__2.label" },
        { "value": "bottom center", "label": "t:sections.allmy-page-hero.settings.image_focus.options__3.label" }
      ],
      "default": "center center"
    },
    { "type": "range", "id": "overlay_opacity", "label": "t:sections.allmy-page-hero.settings.overlay_opacity.label", "min": 0, "max": 90, "step": 5, "default": 0 },
    { "type": "header", "content": "t:sections.allmy-page-hero.settings.header__colors.content" },
    {
      "type": "select", "id": "bg_color", "label": "t:sections.allmy-page-hero.settings.bg_color.label",
      "options": [
        { "value": "#2B2724", "label": "t:sections.allmy-page-hero.settings.bg_color.options__1.label" },
        { "value": "#F5F0E3", "label": "t:sections.allmy-page-hero.settings.bg_color.options__2.label" },
        { "value": "#dde6e3", "label": "t:sections.allmy-page-hero.settings.bg_color.options__3.label" },
        { "value": "#EDE8D9", "label": "t:sections.allmy-page-hero.settings.bg_color.options__4.label" },
        { "value": "#e2b786", "label": "t:sections.allmy-page-hero.settings.bg_color.options__5.label" }
      ],
      "default": "#2B2724"
    },
    {
      "type": "select", "id": "text_color", "label": "t:sections.allmy-page-hero.settings.text_color.label",
      "options": [
        { "value": "#F5F0E3", "label": "t:sections.allmy-page-hero.settings.text_color.options__1.label" },
        { "value": "#2B2724", "label": "t:sections.allmy-page-hero.settings.text_color.options__2.label" }
      ],
      "default": "#F5F0E3"
    },
    {
      "type": "select", "id": "eyebrow_color", "label": "t:sections.allmy-page-hero.settings.eyebrow_color.label",
      "options": [
        { "value": "#e2b786", "label": "t:sections.allmy-page-hero.settings.eyebrow_color.options__1.label" },
        { "value": "#C9B2A3", "label": "t:sections.allmy-page-hero.settings.eyebrow_color.options__2.label" },
        { "value": "#dde6e3", "label": "t:sections.allmy-page-hero.settings.eyebrow_color.options__3.label" },
        { "value": "#F5F0E3", "label": "t:sections.allmy-page-hero.settings.eyebrow_color.options__4.label" }
      ],
      "default": "#e2b786"
    }
  ],
  "presets": [{ "name": "t:sections.allmy-page-hero.presets__1.name" }]
}
{% endschema %}
