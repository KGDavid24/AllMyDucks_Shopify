<style>
  .allmy-cs-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 80px {{ section.settings.padding_bottom }}px;
    text-align: center;
  }

  .allmy-cs-{{ section.id }}__inner {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
  }

  .allmy-cs-{{ section.id }}__heading {
    font-family: var(--font-heading-family);
    font-weight: 700;
    font-size: clamp(28px, 4vw, 52px);
    line-height: 1.12;
    color: {{ section.settings.text_color }};
    margin: 0 0 20px;
  }

  .allmy-cs-{{ section.id }}__subtext {
    font-family: var(--font-body-family);
    font-size: 18px;
    font-weight: 300;
    line-height: 1.65;
    color: {{ section.settings.text_color }};
    opacity: 0.72;
    margin: 0 0 40px;
  }

  @media screen and (max-width: 600px) {
    .allmy-cs-{{ section.id }} { padding: 64px 24px; }
    .allmy-cs-{{ section.id }}__heading { font-size: clamp(26px, 8vw, 36px); }
  }
</style>

<section class="allmy-cs-{{ section.id }}">
  <div class="allmy-cs-{{ section.id }}__inner">
    {% render 'allmy-eyebrow', text: section.settings.eyebrow, color: section.settings.eyebrow_color %}

    {%- if section.settings.heading != blank -%}
      <h2 class="allmy-cs-{{ section.id }}__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="allmy-cs-{{ section.id }}__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {% render 'allmy-btn-link', label: section.settings.btn_label, url: section.settings.btn_url, style: section.settings.btn_style %}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.allmy-cta-strip.name",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "t:sections.allmy-cta-strip.settings.eyebrow.label" },
    { "type": "text", "id": "heading", "label": "t:sections.allmy-cta-strip.settings.heading.label", "default": "Ready to make the switch?" },
    { "type": "textarea", "id": "subtext", "label": "t:sections.allmy-cta-strip.settings.subtext.label" },
    { "type": "text", "id": "btn_label", "label": "t:sections.allmy-cta-strip.settings.btn_label.label", "default": "Shop the range" },
    { "type": "url", "id": "btn_url", "label": "t:sections.allmy-cta-strip.settings.btn_url.label" },
    {
      "type": "select", "id": "btn_style", "label": "t:sections.allmy-cta-strip.settings.btn_style.label",
      "options": [
        { "value": "dark", "label": "t:sections.allmy-cta-strip.settings.btn_style.options__1.label" },
        { "value": "light", "label": "t:sections.allmy-cta-strip.settings.btn_style.options__2.label" },
        { "value": "amber", "label": "t:sections.allmy-cta-strip.settings.btn_style.options__3.label" },
        { "value": "outline-dark", "label": "t:sections.allmy-cta-strip.settings.btn_style.options__4.label" },
        { "value": "outline-light", "label": "t:sections.allmy-cta-strip.settings.btn_style.options__5.label" }
      ],
      "default": "light"
    },
    { "type": "range", "id": "content_width", "label": "t:sections.allmy-cta-strip.settings.content_width.label", "min": 400, "max": 1000, "step": 40, "default": 680 },
    { "type": "range", "id": "padding_top", "label": "t:sections.allmy-cta-strip.settings.padding_top.label", "min": 40, "max": 160, "step": 8, "default": 104 },
    { "type": "range", "id": "padding_bottom", "label": "t:sections.allmy-cta-strip.settings.padding_bottom.label", "min": 40, "max": 160, "step": 8, "default": 104 },
    {
      "type": "select", "id": "bg_color", "label": "t:sections.allmy-cta-strip.settings.bg_color.label",
      "options": [
        { "value": "#2B2724", "label": "t:sections.allmy-cta-strip.settings.bg_color.options__1.label" },
        { "value": "#F5F0E3", "label": "t:sections.allmy-cta-strip.settings.bg_color.options__2.label" },
        { "value": "#dde6e3", "label": "t:sections.allmy-cta-strip.settings.bg_color.options__3.label" },
        { "value": "#e2b786", "label": "t:sections.allmy-cta-strip.settings.bg_color.options__4.label" }
      ],
      "default": "#2B2724"
    },
    {
      "type": "select", "id": "text_color", "label": "t:sections.allmy-cta-strip.settings.text_color.label",
      "options": [
        { "value": "#F5F0E3", "label": "t:sections.allmy-cta-strip.settings.text_color.options__1.label" },
        { "value": "#2B2724", "label": "t:sections.allmy-cta-strip.settings.text_color.options__2.label" }
      ],
      "default": "#F5F0E3"
    },
    {
      "type": "select", "id": "eyebrow_color", "label": "t:sections.allmy-cta-strip.settings.eyebrow_color.label",
      "options": [
        { "value": "#e2b786", "label": "t:sections.allmy-cta-strip.settings.eyebrow_color.options__1.label" },
        { "value": "#C9B2A3", "label": "t:sections.allmy-cta-strip.settings.eyebrow_color.options__2.label" },
        { "value": "#dde6e3", "label": "t:sections.allmy-cta-strip.settings.eyebrow_color.options__3.label" },
        { "value": "#2B2724", "label": "t:sections.allmy-cta-strip.settings.eyebrow_color.options__4.label" }
      ],
      "default": "#e2b786"
    }
  ],
  "presets": [{ "name": "t:sections.allmy-cta-strip.presets__1.name" }]
}
{% endschema %}
