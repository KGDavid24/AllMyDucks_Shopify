<style>
  /* ── ABOUT HERO ── */
  .allmy-about__hero {
    background-color: #2B2724;
    color: #F5F0E3;
    padding: 120px 50px 100px;
    text-align: center;
  }

  .allmy-about__hero-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #DACBA5;
    margin-bottom: 28px;
  }

  .allmy-about__hero-headline {
    font-family: 'Comfortaa', sans-serif;
    font-weight: 700;
    font-size: clamp(32px, 5vw, 58px);
    line-height: 1.18;
    max-width: 820px;
    margin: 0 auto 28px;
    color: #F5F0E3;
  }

  .allmy-about__hero-sub {
    font-size: 17px;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(245,240,227,0.72);
    max-width: 560px;
    margin: 0 auto;
  }

  /* ── STORY GRID ── */
  .allmy-about__story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 560px;
  }

  .allmy-about__story-text {
    background-color: #F5F0E3;
    padding: 80px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .allmy-about__story-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #C9B2A3;
    margin-bottom: 24px;
  }

  .allmy-about__story-heading {
    font-family: 'Comfortaa', sans-serif;
    font-weight: 700;
    font-size: 32px;
    line-height: 1.28;
    color: #2B2724;
    margin-bottom: 28px;
  }

  .allmy-about__story-body {
    font-size: 16px;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(43,39,36,0.8);
  }

  .allmy-about__story-body p + p {
    margin-top: 20px;
  }

  .allmy-about__story-image {
    background-color: #DACBA5;
    position: relative;
    overflow: hidden;
  }

  .allmy-about__story-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .allmy-about__story-image-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .allmy-about__story-image-placeholder img {
    width: 120px;
    height: auto;
    opacity: 0.3;
    object-fit: contain;
  }

  /* ── MISSION PILLARS ── */
  .allmy-about__pillars {
    background-color: #dde6e3;
    border-top: 1px solid rgba(43,39,36,0.06);
    padding: 80px 50px;
    text-align: center;
  }

  .allmy-about__pillars-heading {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #2B2724;
    margin-bottom: 56px;
  }

  .allmy-about__pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    max-width: 960px;
    margin: 0 auto;
  }

  .allmy-about__pillar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .allmy-about__pillar-icon {
    width: 80px;
    height: 80px;
    object-fit: contain;
  }

  .allmy-about__pillar-title {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #2B2724;
  }

  .allmy-about__pillar-desc {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.65;
    color: rgba(43,39,36,0.72);
  }

  /* ── PHILOSOPHY STRIP ── */
  .allmy-about__philosophy {
    background-color: #2B2724;
    padding: 80px 50px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .allmy-about__philosophy-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #DACBA5;
    margin-bottom: 24px;
  }

  .allmy-about__philosophy-quote {
    font-family: 'Comfortaa', sans-serif;
    font-weight: 700;
    font-size: clamp(22px, 3vw, 36px);
    line-height: 1.3;
    color: #F5F0E3;
    margin-bottom: 0;
  }

  .allmy-about__philosophy-detail {
    font-size: 16px;
    font-weight: 300;
    line-height: 1.75;
    color: rgba(245,240,227,0.7);
  }

  .allmy-about__philosophy-detail p + p {
    margin-top: 20px;
  }

  /* ── CTA STRIP ── */
  .allmy-about__cta {
    background-color: #F5F0E3;
    padding: 80px 50px;
    text-align: center;
  }

  .allmy-about__cta-heading {
    font-family: 'Comfortaa', sans-serif;
    font-weight: 700;
    font-size: 28px;
    color: #2B2724;
    margin-bottom: 16px;
  }

  .allmy-about__cta-sub {
    font-size: 16px;
    font-weight: 300;
    color: rgba(43,39,36,0.7);
    margin-bottom: 36px;
  }

  .allmy-about__cta-btn {
    display: inline-block;
    background-color: #e2b786;
    color: #2B2724;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 16px 40px;
    transition: background-color 0.2s ease;
  }

  .allmy-about__cta-btn:hover {
    background-color: #d9a96f;
  }

  /* ── RESPONSIVE ── */
  @media screen and (max-width: 900px) {
    .allmy-about__hero {
      padding: 80px 28px 72px;
    }
    .allmy-about__story {
      grid-template-columns: 1fr;
    }
    .allmy-about__story-image {
      min-height: 320px;
    }
    .allmy-about__story-text {
      padding: 56px 28px;
    }
    .allmy-about__pillars {
      padding: 64px 28px;
    }
    .allmy-about__pillars-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .allmy-about__philosophy {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 64px 28px;
    }
    .allmy-about__cta {
      padding: 64px 28px;
    }
  }
</style>

<!-- HERO -->
<section class="allmy-about__hero">
  <p class="allmy-about__hero-eyebrow">{{ section.settings.eyebrow }}</p>
  <h1 class="allmy-about__hero-headline">{{ section.settings.heading }}</h1>
  <p class="allmy-about__hero-sub">{{ section.settings.text | strip_html }}</p>
</section>

<!-- STORY (layout toggle) -->
{% if section.settings.layout == 'left' %}
<section class="allmy-about__story">
  <div class="allmy-about__story-text">
    <p class="allmy-about__story-eyebrow">{{ 'allmy.about.story_eyebrow' | t: default: 'Our Story' }}</p>
    <h2 class="allmy-about__story-heading">{{ 'allmy.about.story_heading' | t: default: 'Why we started with cleaning.' }}</h2>
    <div class="allmy-about__story-body">
      <p>{{ 'allmy.about.story_p1' | t: default: 'Every home goes through litres of cleaning products a year. Most of that is water — packaged, shipped, and hauled into your home at enormous carbon cost. We thought there had to be a better way.' }}</p>
      <p>{{ 'allmy.about.story_p2' | t: default: 'ALL MY DUCKS is what happens when you decide to start from scratch. No filler. No greenwashing. Concentrated formulas that you dilute at home — in bottles you keep, refill, and rely on.' }}</p>
      <p>{{ 'allmy.about.story_p3' | t: default: "The result is a product that's genuinely better for you and genuinely better for the planet. Not a compromise. Just a smarter way to clean." }}</p>
    </div>
  </div>
  <div class="allmy-about__story-image">
    {% if section.settings.story_image %}
      <img src="{{ section.settings.story_image | img_url: 'master' }}" alt="All My Ducks story" width="800" height="600">
    {% else %}
      <div class="allmy-about__story-image-placeholder">
        <img src="{{ 'brand-logo-standard.svg' | file_url }}" alt="" width="160" height="42">
      </div>
    {% endif %}
  </div>
</section>
{% else %}
<section class="allmy-about__story">
  <div class="allmy-about__story-image">
    {% if section.settings.story_image %}
      <img src="{{ section.settings.story_image | img_url: 'master' }}" alt="All My Ducks story" width="800" height="600">
    {% else %}
      <div class="allmy-about__story-image-placeholder">
        <img src="{{ 'brand-logo-standard.svg' | file_url }}" alt="" width="160" height="42">
      </div>
    {% endif %}
  </div>
  <div class="allmy-about__story-text">
    <p class="allmy-about__story-eyebrow">{{ 'allmy.about.story_eyebrow' | t: default: 'Our Story' }}</p>
    <h2 class="allmy-about__story-heading">{{ 'allmy.about.story_heading' | t: default: 'Why we started with cleaning.' }}</h2>
    <div class="allmy-about__story-body">
      <p>{{ 'allmy.about.story_p1' | t: default: 'Every home goes through litres of cleaning products a year. Most of that is water — packaged, shipped, and hauled into your home at enormous carbon cost. We thought there had to be a better way.' }}</p>
      <p>{{ 'allmy.about.story_p2' | t: default: 'ALL MY DUCKS is what happens when you decide to start from scratch. No filler. No greenwashing. Concentrated formulas that you dilute at home — in bottles you keep, refill, and rely on.' }}</p>
      <p>{{ 'allmy.about.story_p3' | t: default: "The result is a product that's genuinely better for you and genuinely better for the planet. Not a compromise. Just a smarter way to clean." }}</p>
    </div>
  </div>
</section>
{% endif %}

<!-- MISSION PILLARS -->
<section class="allmy-about__pillars">
  <p class="allmy-about__pillars-heading">{{ 'allmy.about.pillars_heading' | t: default: 'What we stand for' }}</p>
  <div class="allmy-about__pillars-grid">
    {% for block in section.blocks %}
      {% if block.type == 'value' %}
        <div class="allmy-about__pillar" {{ block.shopify_attributes }}>
          {% case block.settings.icon %}
            {% when 'water' %}
              <img src="{{ 'brand-icon-no-water.svg' | file_url }}" alt="{{ block.settings.title }}" class="allmy-about__pillar-icon" width="40" height="40">
            {% when 'nature' %}
              <img src="{{ 'brand-icon-naturally.svg' | file_url }}" alt="{{ block.settings.title }}" class="allmy-about__pillar-icon" width="40" height="40">
            {% when 'recycle' %}
              <img src="{{ 'brand-icon-recycled.svg' | file_url }}" alt="{{ block.settings.title }}" class="allmy-about__pillar-icon" width="40" height="40">
            {% else %}
              <img src="{{ 'brand-icon-cleaning.svg' | file_url }}" alt="{{ block.settings.title }}" class="allmy-about__pillar-icon" width="40" height="40">
          {% endcase %}
          <p class="allmy-about__pillar-title">{{ block.settings.title }}</p>
          <p class="allmy-about__pillar-desc">{{ block.settings.desc }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<!-- PHILOSOPHY -->
<section class="allmy-about__philosophy">
  <div>
    <p class="allmy-about__philosophy-label">{{ 'allmy.about.philosophy_label' | t: default: 'Philosophy' }}</p>
    <p class="allmy-about__philosophy-quote">{{ 'allmy.about.philosophy_quote' | t: default: "Premium doesn't have to mean pretentious. It can mean purposeful." }}</p>
  </div>
  <div class="allmy-about__philosophy-detail">
    <p>{{ 'allmy.about.philosophy_p1' | t: default: "Care doesn't have to cost the world. It can heal it. We believe that the best products are the ones that work, last, and leave less behind." }}</p>
    <p>{{ 'allmy.about.philosophy_p2' | t: default: "Concentration isn't a feature — it's a philosophy. It means every drop counts, nothing is wasted, and your home stays clean without the guilt." }}</p>
  </div>
</section>

<!-- CTA -->
<section class="allmy-about__cta">
  <h2 class="allmy-about__cta-heading">{{ 'allmy.about.cta_heading' | t: default: 'Ready to make the switch?' }}</h2>
  <p class="allmy-about__cta-sub">{{ 'allmy.about.cta_sub' | t: default: 'Explore our concentrated cleaning range — designed to last longer, work harder, and ship smarter.' }}</p>
  {% if section.settings.featured_product != blank %}
    {% assign featured = all_products[section.settings.featured_product] %}
    <a href="{{ featured.url }}" class="allmy-about__cta-btn">{{ section.settings.button_label | default: 'DISCOVER' }}</a>
  {% else %}
    <a href="/collections/all" class="allmy-about__cta-btn">{{ section.settings.button_label | default: 'SHOP ALL PRODUCTS' }}</a>
  {% endif %}
</section>

{% schema %}
{
  "name": "Mission & Product Funnel",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "OUR PHILOSOPHY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Hero headline",
      "default": "Premium doesn't have to mean pretentious. It can mean purposeful."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Hero subtext",
      "default": "<p>Care doesn't have to cost the world. It can heal it. We create concentrated cleaning that works, shipping no water, and using strictly recycled materials.</p>"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Story image position",
      "options": [
        { "value": "left", "label": "Image right" },
        { "value": "right", "label": "Image left" }
      ],
      "default": "left"
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Story image"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured product (CTA)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "CTA button label",
      "default": "DISCOVER"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value pillar",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "water", "label": "No Water" },
            { "value": "nature", "label": "Naturally Gentle" },
            { "value": "recycle", "label": "Recycled" },
            { "value": "cleaning", "label": "Cleaning" }
          ],
          "default": "water"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "No Water Shipped"
        },
        {
          "type": "text",
          "id": "desc",
          "label": "Description",
          "default": "Concentrated formula."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mission & Product Funnel",
      "blocks": [
        { "type": "value", "settings": { "icon": "water", "title": "No Water Shipped", "desc": "Concentrated formula means zero water shipped in every bottle." } },
        { "type": "value", "settings": { "icon": "nature", "title": "Naturally Gentle", "desc": "Safe for skin and earth. No harsh chemicals, ever." } },
        { "type": "value", "settings": { "icon": "recycle", "title": "Recycled Plastic Only", "desc": "Thoughtfully repurposed for a cleaner tomorrow." } }
      ]
    }
  ]
}
{% endschema %}
